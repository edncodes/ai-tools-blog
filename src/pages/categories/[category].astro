---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const categories = ['AI Tools', 'Web Development', 'Tutorials', 'Productivity'];
  return categories.map(cat => ({
    params: { category: cat.toLowerCase().replace(/ /g, '-') },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(p => p.data.category === category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title={category} description={`All ${category} tutorials and guides.`}>
  <div class="py-10">
    <a href="/categories" class="text-sm text-blue-500 hover:underline no-underline">← All topics</a>
    <h1 class="text-3xl font-semibold text-gray-900 mt-4 mb-2">{category}</h1>
    <p class="text-gray-500 mb-10">{posts.length} {posts.length === 1 ? 'post' : 'posts'} published</p>
    {posts.length === 0 ? (
      <p class="text-gray-400">No posts in this category yet. Check back soon.</p>
    ) : (
      <div class="flex flex-col gap-4">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="group no-underline flex gap-6 items-start p-5 rounded-2xl border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all">
            <div class="flex-1">
              <div class="flex gap-2 mb-2">
                <span class="text-xs text-gray-400">{post.data.readTime}</span>
              </div>
              <h2 class="text-base font-semibold text-gray-900 group-hover:text-blue-600 leading-snug mb-1">
                {post.data.title}
              </h2>
              <p class="text-sm text-gray-500">{post.data.description}</p>
              <p class="text-xs text-gray-400 mt-2">{post.data.date.toDateString()}</p>
            </div>
            <div class="text-gray-300 group-hover:text-blue-400 transition-colors mt-1 shrink-0">
              <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>