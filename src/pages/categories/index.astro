---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
const categories = ['AI Tools', 'Web Development', 'Tutorials', 'Productivity'];

const countByCategory = categories.map(cat => ({
  name: cat,
  slug: cat.toLowerCase().replace(/ /g, '-'),
  count: posts.filter(p => p.data.category === cat).length,
}));
---
<BaseLayout title="Topics" description="Browse all tutorials by topic.">
  <div class="py-10">
    <h1 class="text-3xl font-semibold text-gray-900 mb-2">Browse by topic</h1>
    <p class="text-gray-500 mb-10">Find tutorials on the subjects that matter to you.</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {countByCategory.map(cat => (
        <a href={`/categories/${cat.slug}`} class="group no-underline p-6 rounded-2xl border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all">
          <h2 class="font-semibold text-gray-900 group-hover:text-blue-600 mb-1">{cat.name}</h2>
          <p class="text-sm text-gray-400">{cat.count} {cat.count === 1 ? 'post' : 'posts'}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>